# ----- Basic Auth -----
# 両方が設定された場合のみ proxy.ts による認証ゲートが有効化される。
# Vercel に投入する際は Production / Preview の両方に設定するのを忘れないこと。
BASIC_AUTH_USER=demo
BASIC_AUTH_PASSWORD=please-change-me-min-8-chars

# ----- GitHub API -----
# 未設定でも動くが、認証なしは 60 req/h と厳しい。
# Personal Access Token (classic / fine-grained どちらでも可) を推奨。
# スコープは public_repo もしくは無印 (検索だけならスコープ無しで十分)。
# https://github.com/settings/tokens
GITHUB_TOKEN=

# ----- メタデータ -----
# OGP の絶対 URL 解決に使う。Vercel では本番ドメインを指定。
NEXT_PUBLIC_SITE_URL=http://localhost:3000
